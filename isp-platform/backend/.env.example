# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/isp_platform
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/isp_platform

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Maps (optional for backend)
GOOGLE_MAPS_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Debug
DEBUG=true